    "dayjs": "^1.11.13",
    "expo-server-sdk": "^3.11.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "imap": "^0.8.19",
    "mailparser": "^2.8.1",
    "mailparser-mit": "^1.0.0",
    "mongodb": "^6.21.0",
    "node-imap": "^0.9.6",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^8.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/cors": "^2.8.19",
    "@types/imap": "^0.8.40",
    "@types/node-imap": "^0.9.3",
    "cors": "^2.8.5",
    "mongodb-memory-server": "^11.2.0",
