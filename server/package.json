{
    "name": "budget-tracker-api",
    "version": "1.0.0",
    "description": "An API providing details regarding remaining weekly budget.",
    "main": "index.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisharrington/budget-tracker.git",
        "directory": "server"
    },
    "author": "Chris Harrington <chrisharrington99@gmail.com>",
    "license": "MIT",
    "scripts": {
        "test": "bun test",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{ts,tsx,json}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
        "api:run": "bun --watch api/app.ts",
        "mail:run": "bun --watch mail/app.ts",
        "database": "docker exec -it $(docker ps --format '{{.ID}} {{.Names}}' | grep 'budget-tracker-database' | cut -d ' ' -f1) mongosh budget"
    },
    "dependencies": {
        "@types/express": "^4.17.21",
        "cron": "^1.8.3",
        "dayjs": "^1.11.13",
        "expo-server-sdk": "^3.11.0",
        "express": "^4.21.0",
        "express-rate-limit": "^8.5.2",
        "mailparser-mit": "^1.0.0",
        "mongodb": "^6.21.0",
        "node-imap": "^0.9.6",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.14",
        "@types/cors": "^2.8.19",
        "@types/node-imap": "^0.9.3",
        "cors": "^2.8.5",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-promise": "^7.3.0",
        "globals": "^17.6.0",
        "mongodb-memory-server": "^11.2.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    }
}
