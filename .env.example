# Budget Tracker environment variables.
#
# Copy this file to `.env` at the repo root and fill in the required values.
# Docker Compose loads `.env` from the directory containing the compose file.
# `.env` is gitignored.
#
# Every variable below is referenced by docker-compose.yml with no inline
# default — set them all before booting the stack.

# --- Compose ---
# Namespaces containers, networks, and per-stack volumes. Keep as
# `budget-tracker` for the primary checkout; sibling git worktrees get a
# distinct name for free (the directory basename) unless overridden here.
COMPOSE_PROJECT_NAME=budget-tracker

# --- MongoDB ---
# The bundled `database` container runs WITHOUT authentication (matching the
# current deployment), so MONGO_URI carries no credentials.
MONGO_URI=mongodb://database:27017
# Logical database name. Selects the Mongo database the server uses
# (server/lib/data/base/index.ts reads this via Config.mongoDb).
MONGO_DB=budget
# Reserved for a future authenticated setup. Leave commented while the
# database runs auth-less — setting these would require credentials in
# MONGO_URI and a data migration.
# MONGO_INITDB_ROOT_USERNAME=
# MONGO_INITDB_ROOT_PASSWORD=

# --- API runtime ---
NODE_ENV=production
# Host port the Express API is published on (container always serves on 9999).
API_PORT=9999

# --- API auth ---
# Shared secret the app sends as `Authorization: Bearer <API_KEY>`. Provisioned
# here now; server-side enforcement is a forthcoming change. Rotate the value
# that previously lived in server/lib/secret.ts.
API_KEY=change_me

# --- IMAP mail listener ---
# Credentials for the mailbox the bank sends transaction notifications to.
# These previously lived in server/lib/secret.ts; they now come from the
# environment. IMPORTANT: that file existed locally in plaintext — rotate the
# Zoho mailbox password before/while populating this file.
MAIL_HOST=imap.zohocloud.ca
MAIL_USER=chrisharringtonbudget@zohomailcloud.ca
MAIL_PASSWORD=change_me

# --- Expo push notifications ---
# Server access token for Expo's push API. Mint one at expo.dev → Account
# Settings → Access Tokens. Leave empty for dev; set in production.
EXPO_ACCESS_TOKEN=

# --- VS Code Dev Container ---
# UID/GID inside the container must match your host user so bind-mounted
# files retain the correct ownership. Check `id` on your host if unsure.
DEV_USER=change_me
DEV_UID=1000
DEV_GID=1000

# Absolute host path to the *primary* checkout's .git directory. The dev
# container bind-mounts this at the same path internally so that worktree
# .git pointer files resolve from inside the container. For the primary
# stack, set this to that stack's own .git; for a worktree stack, set it to
# the primary checkout's .git (NOT the worktree's).
PRIMARY_GIT_DIR=change_me

# --- Metro / Expo dev server ---
# Metro auto-detects a "LAN IP" to embed in bundle/asset URLs; inside the
# container it picks the docker bridge IP (172.x.x.x) which the phone can't
# reach. Set this to your host's LAN address so Metro embeds a reachable URL.
METRO_HOST=change_me
# Host port the Metro bundler binds on (used for both host and container).
METRO_PORT=9097

# --- mongo-express (only used with `--profile tools`) ---
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin
MONGO_EXPRESS_PORT=9098

# --- Running a second stack from a git worktree (optional) ---
# Host ports must not collide between parallel stacks. Suggested offsets:
#
#     Stack                     API_PORT   METRO_PORT   MONGO_EXPRESS_PORT
#     Primary (budget-tracker/) 9999       9097         9098
#     Worktree #1               9989       9197         9198
#     Worktree #2               9979       9297         9298
#
# The shared `budget-tracker-gradle` and `budget-tracker-android` volumes are
# declared `external: true` and must be created once on the host before any
# stack (primary or worktree) boots:
#
#     docker volume create budget-tracker-gradle
#     docker volume create budget-tracker-android
